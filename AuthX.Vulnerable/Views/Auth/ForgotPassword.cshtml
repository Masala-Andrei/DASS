@model ForgotPasswordViewModel
@{
    ViewBag.Title = "Resetare parola";
}

<h1>Am uitat parola</h1>

@if (ViewBag.Error != null)
{
    <div class="alert error">@ViewBag.Error</div>
}

@if (ViewBag.Token != null)
{
    <div class="alert info">
        <p>Token de resetare generat pentru <strong>@ViewBag.Email</strong>:</p>
        <p class="token">@ViewBag.Token</p>
        <p>
            <a class="btn" asp-action="ResetPassword" asp-route-token="@ViewBag.Token">
                Continua cu resetarea
            </a>
        </p>
    </div>
}

<form method="post" asp-action="ForgotPassword">
    <div class="form-group">
        <label asp-for="Email"></label>
        <input asp-for="Email" required />
    </div>
    <button type="submit">Genereaza token de reset</button>
</form>
