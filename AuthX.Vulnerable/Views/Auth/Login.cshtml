@model LoginViewModel
@{
    ViewBag.Title = "Login";
}

<h1>Login</h1>

@if (ViewBag.Error != null)
{
    <div class="alert error">@ViewBag.Error</div>
}

<form method="post" asp-action="Login">
    <div class="form-group">
        <label asp-for="Email"></label>
        <input asp-for="Email" autocomplete="username" required />
    </div>
    <div class="form-group">
        <label asp-for="Password"></label>
        <input asp-for="Password" type="password" autocomplete="current-password" required />
    </div>
    <button type="submit">Autentificare</button>
</form>

<p class="muted" style="margin-top: 1rem;">
    Nu ai cont? <a asp-action="Register">Inregistreaza-te</a> &middot;
    <a asp-action="ForgotPassword">Ai uitat parola?</a>
</p>
