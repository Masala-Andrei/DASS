@model RegisterViewModel
@{
    ViewBag.Title = "Register";
}

<h1>Inregistrare cont nou</h1>

@if (ViewBag.Error != null)
{
    <div class="alert error">@ViewBag.Error</div>
}

<form method="post" asp-action="Register">
    <div class="form-group">
        <label asp-for="Email"></label>
        <input asp-for="Email" required />
    </div>
    <div class="form-group">
        <label asp-for="Password"></label>
        <input asp-for="Password" type="password" required />
    </div>
    <div class="form-group">
        <label asp-for="Role"></label>
        <input asp-for="Role">
    </div>
    <button type="submit">Creeaza cont</button>
</form>

<p class="muted" style="margin-top: 1rem;">
    Ai deja cont? <a asp-action="Login">Login</a>
</p>
