@model ResetPasswordViewModel
@{
    ViewBag.Title = "Reset parola";
}

<h1>Setare parola noua</h1>

@if (ViewBag.Error != null)
{
    <div class="alert error">@ViewBag.Error</div>
}

<form method="post" asp-action="ResetPassword">
    <div class="form-group">
        <label asp-for="Token"></label>
        <input asp-for="Token" required />
    </div>
    <div class="form-group">
        <label asp-for="NewPassword"></label>
        <input asp-for="NewPassword" type="password" required />
    </div>
    <button type="submit">Schimba parola</button>
</form>
