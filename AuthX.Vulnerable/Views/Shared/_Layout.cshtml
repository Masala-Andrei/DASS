@{
    var me = ViewBag.Me as User;
    if (me == null)
    {
        var http = Context;
        var id = http.Request.Cookies["AUTHX_SESSION"];
        if (!string.IsNullOrEmpty(id))
        {
            var db = http.RequestServices.GetService(typeof(AuthX.Vulnerable.Data.AppDbContext)) as AuthX.Vulnerable.Data.AppDbContext;
            if (db != null && int.TryParse(id, out var uid))
            {
                me = db.Users.FirstOrDefault(u => u.Id == uid);
            }
        }
    }
}
<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewBag.Title ?? "AuthX") - AuthX </title>
    <link rel="stylesheet" href="/css/site.css" />
</head>
<body>
    <header class="topbar">
        <div class="topbar-inner">
            <a class="brand" href="/">AuthX</a>
            <nav>
                <a asp-controller="Home" asp-action="Index">Acasa</a>
                <a asp-controller="Tickets" asp-action="Index">Tickete</a>
                @if (me == null)
                {
                    <a asp-controller="Auth" asp-action="Login">Login</a>
                    <a asp-controller="Auth" asp-action="Register">Register</a>
                }
                else
                {
                    <span class="me">@me.Email (@me.Role)</span>
                    <form method="post" asp-controller="Auth" asp-action="Logout" class="inline">
                        <button type="submit" class="link">Logout</button>
                    </form>
                }
            </nav>
        </div>
    </header>

    <main class="container">
        @if (TempData["Info"] != null)
        {
            <div class="alert info">@TempData["Info"]</div>
        }
        @RenderBody()
    </main>

</body>
</html>
