@model Ticket
@{
    ViewBag.Title = $"Ticket #{Model.Id}";
}

<h1>Ticket #@Model.Id &mdash; @Model.Title</h1>

<table>
    <tr><th>Status</th><td>@Model.Status</td></tr>
    <tr><th>Severitate</th><td><span class="severity-@Model.Severity">@Model.Severity</span></td></tr>
    <tr><th>Owner</th><td>@(Model.Owner?.Email ?? Model.OwnerId.ToString())</td></tr>
    <tr><th>Creat</th><td>@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td></tr>
    <tr><th>Actualizat</th><td>@Model.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</td></tr>
</table>

<h2>Descriere</h2>
@* Descrierea este afisata cu Html.Raw, fara escape. *@
<div>@Html.Raw(Model.Description)</div>

<p style="margin-top: 1.5rem;">
    <a asp-action="Index">&larr; Inapoi la lista</a>
</p>
