@{
    ViewBag.Title = "Acasa";
    var me = ViewBag.Me as User;
}

<h1>AuthX</h1>

@if (me == null)
{
    <p>
        <a class="btn" asp-controller="Auth" asp-action="Login">Login</a>
        <a class="btn" asp-controller="Auth" asp-action="Register">Register</a>
    </p>
}
else
{
    <p>Salut, <strong>@me.Email</strong>. Esti logat ca <strong>@me.Role</strong>.</p>
    <p><a class="btn" asp-controller="Tickets" asp-action="Index">Vezi ticketele mele</a></p>
}

