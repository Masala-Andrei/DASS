@model ForgotPasswordViewModel
@{
    ViewBag.Title = "Resetare parola";
    var labToken = TempData["LabResetToken"] as string;
}

<h1>Am uitat parola</h1>

@if (labToken != null)
{
    <div class="alert info">
        <p><strong>[Lab only]</strong> Tokenul de resetare:</p>
        <p class="token">@labToken</p>
        <p>
            <a class="btn" asp-action="ResetPassword" asp-route-token="@labToken">
                Continua cu resetarea
            </a>
        </p>
    </div>
}

<form method="post" asp-action="ForgotPassword">
    @Html.AntiForgeryToken()
    <div class="form-group">
        <label asp-for="Email"></label>
        <input asp-for="Email" />
    </div>
    <button type="submit">Trimite link de reset</button>
</form>
