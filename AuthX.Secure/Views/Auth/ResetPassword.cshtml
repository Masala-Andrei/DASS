@model ResetPasswordViewModel
@{
    ViewBag.Title = "Reset parola";
}

<h1>Setare parola noua</h1>

<form method="post" asp-action="ResetPassword">
    @Html.AntiForgeryToken()
    <div class="form-group">
        @if (ViewBag.TokenError != null)
        {
            <div class="alert error">@ViewBag.TokenError</div>
        }
        <label asp-for="Token"></label>
        <input asp-for="Token" />
    </div>
    <div class="form-group">
        @if (ViewBag.PasswordError != null)
        {
            <div class="alert error">@ViewBag.PasswordError</div>
        }
        <label asp-for="NewPassword"></label>
        <input asp-for="NewPassword" type="password" />
    </div>
    <button type="submit">Schimba parola</button>
</form>
